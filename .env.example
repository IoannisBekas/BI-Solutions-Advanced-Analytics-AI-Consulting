PORT=5001
APP_URL=https://www.bisolutions.group
VITE_QUANTUS_URL=/quantus/workspace/
QUANTUS_API_TARGET=http://127.0.0.1:3001
PYTHON_API_URL=http://127.0.0.1:8000
PYTHON_API_HOST=127.0.0.1

# Security - required in production
JWT_SECRET=
ALLOWED_ORIGINS=https://www.bisolutions.group,https://bisolutions.group
QUANTUS_INTERNAL_KEY=
QUANTUS_PYTHON_TIMEOUT_MS=90000
TRUST_PROXY_HOPS=1

# Database - SQLite file location (default: ./data)
# On Railway, mount a volume and set DATA_DIR to the mount path
DATA_DIR=

# Contact form (Resend email service)
RESEND_API_KEY=
CONTACT_RECIPIENT_EMAIL=
CONTACT_FROM_EMAIL="BI Solutions Contact <contact@bisolutions.group>"

# Bonusaki production pilot
# Keep disabled until a merchant pilot is ready and cashier/admin controls are set.
BONUSAKI_PILOT_ENABLED=false
# At least 32 characters; dedicated secret preferred.
BONUSAKI_TOKEN_SECRET=
# Optional but recommended; at least 32 characters to sign generated QR URLs.
BONUSAKI_QR_SECRET=
# Set true after regenerating a signed QR batch.
BONUSAKI_REQUIRE_SIGNED_QR=false
BONUSAKI_CASHIER_PIN=
# At least 24 characters.
BONUSAKI_ADMIN_KEY=

# AI API keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
POWERBI_SOLUTIONS_ANTHROPIC_API_KEY=
GEMINI_API_KEY=
FMP_API_KEY=
SEC_EDGAR_USER_AGENT=QuantusResearchSolutions/2.4 contact@bisolutions.group
GOOGLE_CLIENT_ID=

# Quantus cache + scanner
SCREENER_SEED_TICKERS=NVDA,TSLA,BTC,SPY,GLD,ASST,AAPL,MSFT,AMZN,GOOGL
