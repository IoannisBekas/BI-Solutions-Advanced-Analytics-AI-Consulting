{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx", "apps/server/index.ts"],
      "port": 5001,
      "env": {
        "PORT": "5001",
        "NODE_ENV": "development"
      }
    },
    {
      "name": "quantus-api",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx", "apps/quantus/server/index.ts"],
      "port": 3001,
      "env": {
        "PORT": "3001",
        "NODE_ENV": "development"
      }
    },
    {
      "name": "quantus-vite",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd apps/quantus && npx vite --port 4500"],
      "port": 4500
    }
  ]
}
